<% content_for :title, "#{@house.name} — GGV Energy" %>

<%= link_to "← All houses", houses_path, class: "text-sm text-slate-500 hover:text-slate-700" %>

<h1 class="mt-2 text-2xl font-semibold text-slate-900"><%= @house.name %></h1>

<%= turbo_stream_from @house %>

<div id="<%= dom_id(@house, :dashboard) %>">
  <%= render "dashboard", house: @house %>
</div>
