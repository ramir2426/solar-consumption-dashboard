<%= render "shared/errors", record: house %>

<%= form_with model: house, class: "space-y-5 rounded-lg border border-slate-200 bg-white p-6" do |f| %>
  <div>
    <%= f.label :name, class: "block text-sm font-medium text-slate-700" %>
    <%= f.text_field :name, class: form_input_classes, autofocus: true %>
    <% if house.errors[:name].any? %>
      <p class="mt-1 text-sm text-red-600"><%= house.errors[:name].to_sentence %></p>
    <% end %>
  </div>

  <div class="border-t border-slate-100 pt-5">
    <%= f.submit class: primary_button_classes %>
  </div>
<% end %>
