<%
  consumers = house.consumers.includes(:market_location, :metering_location, :daily_aggregates).order(:name)
  latest_import = house.latest_import
  timeframe = house.timeframe
%>

<section class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
  <div class="rounded-lg border border-slate-200 bg-white p-5">
    <p class="text-sm text-slate-500">Total solar consumption</p>
    <p class="mt-1 text-2xl font-semibold text-slate-900"><%= number_with_precision(house.solar_total, precision: 2) %> <span class="text-base font-normal text-slate-400">kWh</span></p>
  </div>
  <div class="rounded-lg border border-slate-200 bg-white p-5">
    <p class="text-sm text-slate-500">Average daily solar consumption</p>
    <p class="mt-1 text-2xl font-semibold text-slate-900"><%= number_with_precision(house.average_daily_solar, precision: 2) %> <span class="text-base font-normal text-slate-400">kWh/day</span></p>
  </div>
  <div class="rounded-lg border border-slate-200 bg-white p-5">
    <p class="text-sm text-slate-500">Solar coverage</p>
    <% if (ratio = house.solar_coverage_ratio) %>
      <p class="mt-1 text-2xl font-semibold text-slate-900"><%= ratio %><span class="text-base font-normal text-slate-400">%</span></p>
      <div class="mt-2.5 h-1.5 w-full rounded-full bg-slate-100">
        <div class="h-1.5 rounded-full bg-amber-500" style="width: <%= [ ratio, 100 ].min %>%"></div>
      </div>
    <% else %>
      <p class="mt-1 text-sm text-slate-400">No data imported yet</p>
    <% end %>
  </div>
  <div class="rounded-lg border border-slate-200 bg-white p-5">
    <p class="text-sm text-slate-500">Timeframe</p>
    <% if timeframe&.first %>
      <p class="mt-1 text-sm font-medium text-slate-900"><%= timeframe.first.strftime("%b %-d, %Y") %> &ndash; <%= timeframe.last.strftime("%b %-d, %Y") %></p>
    <% else %>
      <p class="mt-1 text-sm text-slate-400">No data imported yet</p>
    <% end %>
  </div>
</section>

<section class="mt-6 rounded-lg border border-slate-200 bg-white p-5">
  <div class="flex items-center justify-between">
    <h2 class="font-medium text-slate-900">Import</h2>
    <%= render "houses/import_status", import: latest_import if latest_import %>
  </div>

  <% if latest_import&.running? %>
    <p class="mt-4 text-sm text-slate-500">
      Fetching load-profile data since <%= latest_import.begin_date %>… this section refreshes on its own, no need to reload.
    </p>
  <% else %>
    <%= form_with url: house_imports_path(house), method: :post, class: "mt-4 flex flex-wrap items-end gap-3" do |f| %>
      <div>
        <label class="block text-xs font-medium text-slate-500" for="begin_date">From date</label>
        <%= f.date_field :begin_date, value: 30.days.ago.to_date, max: Date.current,
              class: "mt-1 rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      </div>
      <%= f.submit "Import data from API", class: primary_button_classes %>
    <% end %>
  <% end %>

  <% if latest_import&.error_message.present? %>
    <p class="mt-3 whitespace-pre-line rounded-md bg-amber-50 px-3 py-2 text-sm text-amber-800"><%= latest_import.error_message %></p>
  <% end %>
</section>

<section class="mt-6">
  <div class="flex items-center justify-between">
    <h2 class="font-medium text-slate-900">Consumers</h2>
    <%= link_to "New consumer", new_house_consumer_path(house), class: "text-sm text-slate-500 hover:text-slate-900 hover:underline" %>
  </div>

  <div class="mt-3 overflow-x-auto rounded-lg border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3">Consumer</th>
          <th class="px-4 py-3">Total solar consumption</th>
          <th class="px-4 py-3">Average daily</th>
          <th class="px-4 py-3">Solar coverage</th>
          <th class="px-4 py-3">Data quality</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% consumers.each do |consumer| %>
          <tr>
            <td class="px-4 py-3 font-medium text-slate-900">
              <%= link_to consumer.name, house_consumer_path(house, consumer), class: "hover:underline" %>
            </td>
            <td class="px-4 py-3 text-slate-700"><%= number_with_precision(consumer.solar_total, precision: 2) %> kWh</td>
            <td class="px-4 py-3 text-slate-700"><%= number_with_precision(consumer.average_daily_solar, precision: 2) %> kWh/day</td>
            <td class="px-4 py-3 text-slate-700"><%= render "shared/solar_coverage", ratio: consumer.solar_coverage_ratio %></td>
            <td class="px-4 py-3">
              <% if consumer.daily_aggregates.empty? %>
                <span class="text-slate-400">No data yet</span>
              <% elsif consumer.daily_aggregates.where(complete: false).exists? %>
                <span class="text-amber-600">Partial data on some days</span>
              <% else %>
                <span class="text-emerald-600">Complete</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-right">
              <%= button_to "Remove", house_consumer_path(house, consumer), method: :delete,
                    class: "text-sm text-slate-400 hover:text-red-600 hover:underline cursor-pointer bg-transparent border-0 p-0",
                    form: { data: { turbo_confirm: "Remove #{consumer.name} and all of its imported data? This can't be undone." } } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
