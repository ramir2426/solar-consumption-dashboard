<%
  # A small dependency-free bar chart: no JS chart library needed for
  # ~30-90 data points, and the native <title> gives a tooltip for free.
  max_value = [ daily_aggregates.map { |row| row.solar_total.to_f }.max.to_f, 0.01 ].max
  bar_width = 8
  gap = 4
  chart_width = daily_aggregates.size * (bar_width + gap)
%>
<div class="mt-3 overflow-x-auto">
  <svg viewBox="0 0 <%= chart_width %> 100" preserveAspectRatio="none" class="h-32" style="width: <%= [chart_width, 600].max %>px">
    <% daily_aggregates.each_with_index do |row, index| %>
      <%
        height = (row.solar_total.to_f / max_value * 96).round(1)
        x = index * (bar_width + gap)
      %>
      <rect
        x="<%= x %>"
        y="<%= 100 - height %>"
        width="<%= bar_width %>"
        height="<%= height %>"
        rx="1.5"
        class="<%= row.complete? ? "fill-indigo-500" : "fill-amber-400" %>"
      >
        <title><%= row.date.strftime("%b %-d") %>: <%= number_with_precision(row.solar_total, precision: 2) %> kWh<%= " (partial data)" unless row.complete? %></title>
      </rect>
    <% end %>
  </svg>
</div>
