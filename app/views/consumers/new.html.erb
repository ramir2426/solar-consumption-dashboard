<% content_for :title, "New consumer — #{@house.name}" %>

<%= link_to "← #{@house.name}", house_path(@house), class: "text-sm text-slate-500 hover:text-slate-700" %>

<h1 class="mt-2 text-2xl font-semibold text-slate-900">New consumer</h1>

<div class="mt-8 max-w-md">
  <%= render "shared/errors", record: @consumer %>

  <%= form_with model: [ @house, @consumer ], class: "space-y-5 rounded-lg border border-slate-200 bg-white p-6" do |f| %>
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :name, class: form_input_classes, autofocus: true %>
      <% if @consumer.errors[:name].any? %>
        <p class="mt-1 text-sm text-red-600"><%= @consumer.errors[:name].to_sentence %></p>
      <% end %>
    </div>

    <%= f.fields_for :locations do |lf| %>
      <div>
        <% if lf.object.market? %>
          <%= lf.label :location_id, "Market location ID (10 digits)", class: "block text-sm font-medium text-slate-700" %>
        <% else %>
          <%= lf.label :location_id, "Metering location ID (33 characters)", class: "block text-sm font-medium text-slate-700" %>
        <% end %>
        <%= lf.hidden_field :location_type %>
        <%= lf.text_field :location_id, class: "#{form_input_classes} font-mono" %>
        <% if lf.object.errors[:base].any? %>
          <p class="mt-1 text-sm text-red-600"><%= lf.object.errors[:base].to_sentence %></p>
        <% end %>
      </div>
    <% end %>

    <div class="border-t border-slate-100 pt-5">
      <%= f.submit class: primary_button_classes %>
    </div>
  <% end %>
</div>
